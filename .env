# Konfigurasi Kamera
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30

# Konfigurasi OCR
OCR_INTERVAL=10
OCR_SCALE=0.5

# Konfigurasi Display
TEXTBOX_HEIGHT=150
TEXT_COLOR=0,255,0
TEXT_SIZE=0.5
TEXT_THICKNESS=1

# Konfigurasi PaddleOCR
PADDLE_LANG=en
PADDLE_USE_ANGLE_CLS=True
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True

# Konfigurasi Performa
SHOW_FPS=True
SHOW_FOCUS_INFO=True
DEBUG_MODE=False             # MATIKAN! Print banyak bikin lag

# ============================================
# SMART OCR MODE - Fokus dulu, baru scan
# ============================================
SMART_OCR_MODE=True
FOCUS_WAIT_TIME=2            # Detik tunggu kamera fokus (tanpa OCR)
DISPLAY_DURATION=5           # Detik tampilkan hasil sebelum scan ulang
BLUR_THRESHOLD=46            # Threshold ketajaman gambar (越高越清晰) persentase %
MIN_CONFIDENCE=0.8           # Confidence minimum untuk istirahat

# ============================================
# OCR AGGREGATION - Kumpulkan multi-frame
# ============================================
USE_AGGREGATION=True         # Aktifkan voting multi-frame
AGGREGATION_FRAMES=5         # Kumpulkan 3 hasil OCR (turunkan dari 5)
MIN_VOTE_COUNT=3             # Teks harus muncul minimal 2x
CONFIDENCE_THRESHOLD=0.8     # Filter confidence di bawah ini
USE_WEIGHTED_VOTE=True       # Vote dengan bobot confidence

# ============================================
# CPU OPTIMIZATION
# ============================================
OCR_INTERVAL=10              # Naikkan! OCR lebih jarang (hemat CPU)

# ============================================
# MEMORY MANAGEMENT
# ============================================
ENABLE_MEMORY_CLEANUP=True   # Aktifkan garbage collector otomatis
MEMORY_CLEANUP_INTERVAL=30   # Detik, cleanup memory setiap 30 detik

# ============================================
# OPSI OPTIMASI OCR (uncomment untuk aktivasi)
# ============================================
# OCR_SCALE=0.2              # Resize frame jadi 20% (sangat cepat, ~30-50ms)
# PADDLE_USE_ANGLE_CLS=False # Matikan angle classifier (hemat ~30-50ms)

# Opsi ekstrem untuk speed maksimal:
# OCR_SCALE=0.15             # Resize 15% (super cepat, akurasi turun)
# OCR_INTERVAL=20            # OCR lebih jarang (hemat CPU)

# Opsi balanced (recommended):
# OCR_SCALE=0.3              # Resize 30% (cukup cepat, ~50-100ms)
# OCR_INTERVAL=10            # OCR setiap 10 frame
# PADDLE_USE_ANGLE_CLS=False # Hemat 30-50ms tanpa banyak pengaruh akurasi
