# ========================================
# PaddleOCR Mobile - Configuration
# ========================================

# ----------------------------------------
# OCR Settings
# ----------------------------------------
# Language: 'en' (English) or 'id' (Indonesian)
OCR_LANG=en

# Confidence threshold (0.0 - 1.0)
# Text with confidence below this will be filtered out
CONF_THRESHOLD=0.5

# ----------------------------------------
# Text Processing Settings
# ----------------------------------------
# Delete all spaces from detected text
# True = Remove all spaces (e.g., "ABC 123" -> "ABC123")
# False = Keep spaces (e.g., "ABC 123" -> "ABC 123")
DELETE_SPACE=True

# Group text by horizontal lines (rows)
# True = Group texts on same horizontal line together
# False = Keep individual text detections separate
# Example: "HELLO" and "WORLD" on same line -> "HELLO WORLD"
GROUP_BY_LINE=True

# Tolerance for grouping (pixels difference in y-coordinate)
# Texts within this y-difference will be grouped together
LINE_TOLERANCE=10

# ----------------------------------------
# Indonesian Plate Processing Settings
# ----------------------------------------
# Enable Indonesian license plate validation & correction
# True = Validate and correct detected text based on Indonesian plate format
# False = Return OCR results as-is
# This helps fix common OCR errors like: 0↔O, 8↔B, 1↔I, etc.
# Position-based correction:
#   - Numbers section: O→0, B→8, I→1, S→5, Z→2, G→6, Q→9
#   - Letters section: 0→O, 8→B, 1→I, 5→S, 2→Z, 6→G, 9→Q
USE_INDONESIAN_PLATE_PROCESSOR=True

# If validation fails, return original OCR result (fallback)
# True = Return original text if format doesn't match Indonesian plate structure
# False = Return corrected text even if validation fails
INDONESIAN_PLATE_FALLBACK_TO_ORIGINAL=True

# Hide popup on "Unknown exception" error
# True = Auto-retry without showing popup (silent retry)
# False = Show error popup, then auto-retry after user clicks OK
# HIDE_POPUP_UNKNOWN_EXCEPTION=False
HIDE_POPUP_UNKNOWN_EXCEPTION=True

# ----------------------------------------
# Output Settings
# ----------------------------------------
# Show result image with bounding boxes
SHOW_RESULT=True

# Save results to files
SAVE_RESULT=True

# Output directory
OUTPUT_DIR=output

# Draw bounding boxes on detected text
DRAW_BOX=True

# Box color (BGR format)
BOX_COLOR=0,255,0

# Text color (BGR format)
TEXT_COLOR=0,0,255

# ----------------------------------------
# PaddleOCR Model Info
# ----------------------------------------
# Models used: PP-OCRv5_mobile_det + PP-OCRv5_mobile_rec
# Total size: ~15MB
# Speed: ~100ms per image on CPU
# ========================================
