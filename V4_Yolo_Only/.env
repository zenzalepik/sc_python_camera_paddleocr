# ========================================
# YOLOv8 Live Streaming Camera
# Configuration File
# ========================================

# ----------------------------------------
# Camera Settings
# ----------------------------------------
CAMERA_ID=0                  # Camera device ID (0 = default camera)
CAMERA_WIDTH=640             # Frame width
CAMERA_HEIGHT=480            # Frame height
CAMERA_FPS=30                # Target FPS

# ----------------------------------------
# YOLO Model Settings
# ----------------------------------------
# Model options:
#   - yolov8n.pt  = Nano (fastest, recommended for real-time)
#   - yolov8s.pt  = Small (balanced)
#   - yolov8m.pt  = Medium (more accurate, slower)
#   - yolov8l.pt  = Large (very accurate, slow)
#   - yolov8x.pt  = Extra large (most accurate, slowest)
YOLO_MODEL=yolov8n.pt        # Nano = fastest for real-time

CONF_THRESHOLD=0.4           # Minimum confidence (0.1 - 0.9)
IOU_THRESHOLD=0.45           # NMS IoU threshold

# Class Filter (optional)
# Leave empty to detect all 80 COCO classes
# Examples:
#   CLASSES_FILTER=person
#   CLASSES_FILTER=person,car,motorcycle
#   CLASSES_FILTER=car,bus,truck
CLASSES_FILTER=

# ----------------------------------------
# Display Settings
# ----------------------------------------
SHOW_FPS=True
SHOW_CONFIDENCE=True
SHOW_CLASS_ID=False
SHOW_LABELS=True
BOX_THICKNESS=2
TEXT_SIZE=0.5
TEXT_THICKNESS=1

# ----------------------------------------
# Performance Settings
# ----------------------------------------
USE_GPU=True                 # Use GPU if available (CUDA)
HALF_PRECISION=True          # Use FP16 for faster inference (GPU only)

# ----------------------------------------
# Storage Settings
# ----------------------------------------
SAVE_SNAPSHOTS=True
SNAPSHOT_DIR=snapshots

SAVE_RECORDING=False         # Set to True to enable recording
RECORDING_DIR=recordings

# ----------------------------------------
# YOLO Version Comparison
# ----------------------------------------
# Model      | Size (MB) | Parameters | mAP    | Speed (CPU) | Speed (GPU)
# -----------|-----------|------------|--------|-------------|-------------
# yolov8n.pt |    6.2    |    3.2M    |  37.3  |   ~80 FPS   |   ~350 FPS
# yolov8s.pt |   21.5    |   11.2M    |  44.9  |   ~40 FPS   |   ~200 FPS
# yolov8m.pt |   49.7    |   25.9M    |  50.2  |   ~20 FPS   |   ~100 FPS
# yolov8l.pt |   97.5    |   43.7M    |  52.9  |   ~12 FPS   |    ~60 FPS
# yolov8x.pt |  144.4    |   68.2M    |  53.9  |    ~8 FPS   |    ~45 FPS
#
# Recommendation for live streaming:
#   - Real-time on CPU: yolov8n.pt (Nano) ✅
#   - Real-time on GPU: yolov8n.pt or yolov8s.pt ✅
#   - Best accuracy: yolov8x.pt (but slower)
# ========================================
