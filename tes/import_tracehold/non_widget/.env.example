# ============================================
# Environment Variables Configuration
# ============================================
# Copy this file to .env and edit the values
# Usage: 
#   Windows: set BG_DIFF_THRESHOLD=50 && python main.py
#   Linux/Mac: export BG_DIFF_THRESHOLD=50 && python main.py
#   Or use: python -c "import os; os.environ['BG_DIFF_THRESHOLD']='50'" && python main.py

# Background Difference Threshold (0-255)
# Higher = less sensitive (more noise ignored)
# Default: 40
BG_DIFF_THRESHOLD=40

# Frame Difference Threshold (0-255)
# Higher = less sensitive to motion
# Default: 40
FRAME_DIFF_THRESHOLD=40

# Auto Reset Enabled (True/False)
# Default: True
AUTO_RESET_ENABLED=True

# No Motion Threshold (frames)
# Frames without motion before auto reset
# Default: 60 (≈2 seconds at 30 FPS)
NO_MOTION_THRESHOLD=60

# Object Confirm Threshold (frames)
# Frames to confirm object presence
# Default: 3
OBJECT_CONFIRM_THRESHOLD=3

# Object Lost Threshold (frames)
# Frames before object considered gone
# Default: 30 (≈1 second at 30 FPS)
OBJECT_LOST_THRESHOLD=30

# Minimum Contour Area
# Minimum pixel area to be considered an object
# Default: 800
MIN_CONTOUR_AREA=800

# Initialization Capture Count
# Number of frames captured during initialization
# Default: 15
INIT_CAPTURE_COUNT=15

# Initialization Selection Method
# "average", "majority", or "strict"
# Default: majority
INIT_SELECTION_METHOD=majority

# Initialization Similarity Threshold (0-1)
# Similarity threshold for voting
# Default: 0.85
INIT_SIMILARITY_THRESHOLD=0.85

# Initialization Strict Min Votes
# Minimum votes required for strict mode
# Default: 10
INIT_STRICT_MIN_VOTES=10
