# ============================================
# PARKING LPR SYSTEM - Configuration
# ============================================

# Konfigurasi Kamera
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30

# ============================================
# PARKING MODE CONFIGURATION
# ============================================
PARKING_MODE=True            # Aktifkan mode parkir (ROI + Trigger)
LPR_MODE=True                # True = khusus plat nomor, False = semua teks
MOTION_TRIGGER=True          # Gunakan motion detection sebagai trigger
MOTION_THRESHOLD=25          # Sensitivitas motion (0-100)

# ============================================
# ROI (Region of Interest) - Area Deteksi Plat
# ============================================
ROI_ENABLED=True
ROI_X=150                    # Posisi X kiri atas ROI
ROI_Y=180                    # Posisi Y kiri atas ROI
ROI_WIDTH=340                # Lebar area ROI
ROI_HEIGHT=200               # Tinggi area ROI

# ============================================
# PLATE DETECTION
# ============================================
PLATE_DETECTION_MODE=contour # 'contour' (cepat) atau 'yolo' (akurat)
MIN_PLATE_AREA=500           # Area minimal plat
MAX_PLATE_AREA=50000         # Area maksimal plat

# ============================================
# MULTI-FRAME BEST SELECTION
# ============================================
MULTI_FRAME_SELECTION=True
BEST_FRAME_COUNT=8           # Kumpulkan 8 frame untuk dipilih yang terbaik
FOCUS_WEIGHT=0.5             # Bobot ketajaman
BRIGHTNESS_WEIGHT=0.3        # Bobot kecerahan
ANGLE_WEIGHT=0.2             # Bobot sudut plat

# ============================================
# OCR CONFIGURATION
# ============================================
OCR_SCALE=1.0                # Jangan resize plat (sudah kecil)
PADDLE_LANG=en
PADDLE_USE_ANGLE_CLS=True
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True

# PaddleOCR ONNX Mode
# True = Use ONNX optimized model (faster, ~80ms, lower accuracy)
# False = Use mobile model (default, ~150ms, balanced)
PADDLE_OCR_ONNX=False

# ============================================
# PLATE VALIDATION (Regex Indonesia)
# ============================================
ENABLE_PLATE_VALIDATION=True
PLATE_FORMAT_REGEX=^[A-Z]{1,2}\\s?\\d{3,4}\\s?[A-Z]{0,3}$

# ============================================
# DISPLAY & UI
# ============================================
SHOW_FPS=True
SHOW_ROI_BOX=True            # Tampilkan kotak ROI
SHOW_PLATE_BOX=True          # Tampilkan kotak plat terdeteksi
SHOW_DEBUG_INFO=True         # Tampilkan info debug
RESULT_DISPLAY_DURATION=10   # Detik tampilkan hasil deteksi di layar

# ============================================
# DATABASE & LOGGING
# ============================================
ENABLE_DATABASE=True         # Simpan hasil ke SQLite
DATABASE_PATH=parking.db     # Nama file database
AUTO_SAVE=True               # Auto save saat plat valid

# ============================================
# GATE CONTROL (Optional)
# ============================================
ENABLE_GATE_CONTROL=False    # Kontrol palang otomatis
GATE_OPEN_DURATION=5         # Detik palang terbuka
RELAY_PIN=17                 # GPIO pin untuk relay (Raspberry Pi)

# ============================================
# PERFORMA & MEMORY
# ============================================
DEBUG_MODE=False
ENABLE_MEMORY_CLEANUP=True
MEMORY_CLEANUP_INTERVAL=60   # Cleanup memory setiap 60 detik
