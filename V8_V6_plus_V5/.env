# ========================================
# V8 Parking System - Configuration
# ========================================

# ----------------------------------------
# PERFORMANCE MODE
# ----------------------------------------
# Pilih mode performa:
# - HIGH:   Full detection (30 FPS), semua frame di-detect
#           CPU Usage: ~90-100%
#           Kualitas: 100%
#
# - MEDIUM: Optimized detection (15 FPS, detect setiap 3 frame)
#           CPU Usage: ~30-40%
#           Kualitas: 90%
#
# - LOW:    Throttled detection (detect setiap 0.1 detik / 100ms)
#           CPU Usage: ~20-30%
#           Kualitas: 85%
# ----------------------------------------
PERFORMANCE_MODE=LOW

# ----------------------------------------
# CAPTURE FRAMES PER FASE
# ----------------------------------------
# Atur jumlah capture untuk setiap fase
# 
# Nilai yang diperbolehkan:
# - 0 = Skip fase ini (tidak ada capture, tidak ada OCR)
# - 1-10 = Jumlah frame yang akan di-capture dan di-OCR
#
# Rekomendasi:
# - FASE 1: 3-5 frame (mendekat)
# - FASE 2: 5-7 frame (berhenti - untuk OCR)
# - FASE 3: 3-5 frame (loop detector)
# - FASE 4: 3-5 frame (tap card)
#
# Contoh setup cepat:
# - Fast Processing: FASE1=3, FASE2=3, FASE3=0, FASE4=0 (6 frame total)
# - Balanced: FASE1=3, FASE2=5, FASE3=3, FASE4=3 (14 frame total)
# - Complete: FASE1=5, FASE2=7, FASE3=5, FASE4=5 (22 frame total)
# - OCR Only: FASE1=0, FASE2=7, FASE3=0, FASE4=0 (7 frame total)
# ----------------------------------------
FASE1_CAPTURE_COUNT=3
FASE2_CAPTURE_COUNT=5
FASE3_CAPTURE_COUNT=3
FASE4_CAPTURE_COUNT=3

# ----------------------------------------
# YOLO Detection
# ----------------------------------------
CONFIDENCE_THRESHOLD=0.5
CAMERA_ID=0

# ----------------------------------------
# OCR Settings
# ----------------------------------------
OCR_LANG=en
OCR_CONF_THRESHOLD=0.5

# ----------------------------------------
# Output Settings
# ----------------------------------------
OUTPUT_DIR=captures
