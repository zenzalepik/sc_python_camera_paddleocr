# ========================================
# YOLOv8-Nano + HyperLPR (LPR Mode)
# Configuration File
# ========================================

# ----------------------------------------
# Camera Settings
# ----------------------------------------
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30

# ----------------------------------------
# YOLO Model Settings
# ----------------------------------------
YOLO_MODEL=yolov8n.pt        # yolov8n = nano (fastest)
YOLO_CONF_THRESHOLD=0.4      # Minimum confidence
YOLO_IOU_THRESHOLD=0.45      # NMS IoU threshold

# Vehicle Classes Filter (COCO: 2=car, 3=motorcycle, 5=bus, 7=truck)
YOLO_CLASSES_FILTER=2,3,5,7

# ----------------------------------------
# Vehicle Detection Mode
# ----------------------------------------
# When True: Only detect vehicles (car, motorcycle, bus, truck)
#            OCR will run on vehicle regions only
# When False: Detect ALL objects (80 COCO classes)
#            OCR will run on any detected object
# Default: False (for easy plate testing)
VEHICLE_DETECTION_ACTIVE=False

# ----------------------------------------
# LPR (License Plate Recognition) Settings
# ----------------------------------------
LPR_ACTIVE=True              # Enable LPR mode
LPR_ENGINE=hyperlpr          # 'hyperlpr' (primary) or 'paddleocr' (fallback)

# LPR Detection Mode
# FULL_FRAME: Scan entire frame for plates/text (slower but finds everything)
# DETECTION_BASED: Only OCR on detected objects (faster, needs YOLO detection)
LPR_DETECTION_MODE=FULL_FRAME

# LPR-specific settings
LPR_MIN_PLATE_AREA=500       # Minimum area for plate region
LPR_MAX_PLATE_ASPECT=5.0     # Max aspect ratio (width/height)
LPR_MIN_PLATE_ASPECT=1.5     # Min aspect ratio (width/height)

# Plate format validation (Indonesia)
LPR_VALIDATE_PLATE=True
LPR_PLATE_COUNTRY=id

# ----------------------------------------
# OCR Settings (PaddleOCR) - For General Objects
# ----------------------------------------
# Note: Using HyperLPR for LPR, PaddleOCR for general OCR
OCR_ENABLED=True               # Enable OCR for non-vehicle objects
OCR_ON_CLASSES=cell phone,book,laptop,document  # Classes to run OCR on
OCR_SCALE=1.0                  # Full resolution for text reading

# Cell Phone OCR Settings
PHONE_OCR_ACTIVE=True          # Enable OCR when cell phone detected
PHONE_OCR_INTERVAL=3           # Process every 3 frames (balance performance)

# ----------------------------------------
# Display Settings
# ----------------------------------------
SHOW_FPS=True
SHOW_CONFIDENCE=True
SHOW_CLASS_ID=False
SHOW_OCR_RESULT=True
TEXT_SIZE=0.5
TEXT_THICKNESS=1
BOX_THICKNESS=2

# ----------------------------------------
# Performance Settings
# ----------------------------------------
FRAME_SKIP=1
DEBUG_MODE=False
ENABLE_MEMORY_CLEANUP=True
MEMORY_CLEANUP_INTERVAL=30

# ----------------------------------------
# Tracking Settings
# ----------------------------------------
ENABLE_TRACKING=True
TRACKER_TYPE=bytetrack.yaml
